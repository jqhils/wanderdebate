# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key                     # Public anon key for client
SUPABASE_SECRET_KEY=your-secret-key             # Server-only (recommended)
SUPABASE_SERVICE_ROLE_KEY=your-service-key      # Server-only (legacy alias; still supported here)

# Mistral (server-only)
NUXT_MISTRAL_API_KEY=your-mistral-api-key

# MiniMax (server-only, required only if llm provider = minimax)
NUXT_MINIMAX_API_KEY=your-minimax-api-key
NUXT_MINIMAX_BASE_URL=https://api.minimax.io/v1

# Feature flags
NUXT_DAILY_ITINERARY_LIMIT_ENABLED=TRUE
